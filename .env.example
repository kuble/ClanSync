# ClanSync — 로컬 개발 ENV 템플릿
#
# 로컬 개발 시:
#   cp .env.example .env.local
# 후 값을 채운다. `.env.local` 은 `.gitignore` 로 커밋 차단.
#
# Vercel 배포(Preview/Production)는 프로젝트 설정의 Environment Variables 에서
# 동일한 키를 등록한다. `NEXT_PUBLIC_SITE_URL` 은 환경별로 실제 URL 로 덮어쓴다.

# -----------------------------------------------------------------------------
# Supabase — 클라이언트/서버 공용
# -----------------------------------------------------------------------------

# Supabase 프로젝트 URL. 클라이언트 번들에 포함됨(public).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key. 클라이언트 번들에 포함됨(public) — RLS 로 보호.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 현재 환경의 루트 URL. 이메일 매직 링크·OAuth 리다이렉트에서 사용.
#   local:      http://localhost:3000
#   preview:    https://<preview-hash>.vercel.app
#   production: https://clansync.app (예시)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase — 서버 전용 (NEXT_PUBLIC_ 접두사 금지)
# -----------------------------------------------------------------------------

# Service role key. Server Action · Route Handler · 마이그레이션에서만 사용.
# 절대 클라이언트 번들에 노출되면 안 됨.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI — 원격 프로젝트에 `db push` 하기 전 (택1)
#   1) 터미널에서 `npx supabase login` 한 번 (브라우저 로그인)
#   2) 또는 대시보드 Personal Access Token 을 여기에 넣고 세션에 로드
# SUPABASE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# 테스트 어시스트 (로컬 QA · E2E 전용)
# -----------------------------------------------------------------------------

# 시드 계정 공통 비밀번호 (D-AUTH-03 strong 정책을 통과하는 값).
QA_SEED_PASSWORD=

# Playwright / E2E 기본 테스트 계정 (`db:seed` 와 동일 이메일 권장).
E2E_TEST_EMAIL=fixture-solo@clansync-qa.local
E2E_TEST_PASSWORD=
