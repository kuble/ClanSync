# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# bkit — tool-managed local state (PDCA snapshots, memory)
.bkit/snapshots/
.bkit/state/

# vendor icon packs — full pack lives on disk for future use, but git only tracks
# the icons we copy into each pack's `in-use/` subfolder (whitelist).
# To use an icon: copy the SVG into `<pack>/in-use/...` and commit it.
# NOTE: use `/*` (not `/`) so the directory itself is not ignored — otherwise
# negation patterns inside it cannot re-include anything.
mockup/assets/icons/ionicons.designerpack/*
!mockup/assets/icons/ionicons.designerpack/in-use/
!mockup/assets/icons/ionicons.designerpack/in-use/**
!mockup/assets/icons/ionicons.designerpack/README.in-use.md
mockup/assets/icons/heroicons/*
!mockup/assets/icons/heroicons/in-use/
!mockup/assets/icons/heroicons/in-use/**
!mockup/assets/icons/heroicons/README.in-use.md
